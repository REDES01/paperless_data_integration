# Paperless-ngx environment file — rename to docker-compose.env before use.
# Generate PAPERLESS_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"

# Host address — leave commented for default
#PAPERLESS_URL=https://paperless.example.com

# Time zone and OCR languages
PAPERLESS_TIME_ZONE=America/New_York
PAPERLESS_OCR_LANGUAGE=eng

# Secret key — REQUIRED for source builds. Do not commit a real one.
PAPERLESS_SECRET_KEY=replace-me-with-a-real-secret

# Database (matches services in docker-compose.yml)
PAPERLESS_DBHOST=db
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=paperless

# Redis broker
PAPERLESS_REDIS=redis://broker:6379

# --- Phase 1 ML integration ---
# Connection to the data-stack Postgres (paperless_data) on paperless_ml_net.
# These are read by paperless_ml.db.ml_cursor() to write/read the ML schema
# (handwritten_regions, htr_corrections, search_feedback, ...).
# The hostname matches the data stack's container_name.
PAPERLESS_ML_DBHOST=postgres
PAPERLESS_ML_DBPORT=5432
PAPERLESS_ML_DBNAME=paperless
PAPERLESS_ML_DBUSER=user
PAPERLESS_ML_DBPASSWORD=paperless_postgres

# --- Phase 4 (upload events to Redpanda) ---
# Where the paperless_ml app publishes upload events.
# Hostname matches the data stack's redpanda container_name.
PAPERLESS_ML_KAFKA_BROKER=redpanda:9092
PAPERLESS_ML_KAFKA_TOPIC=paperless.uploads
