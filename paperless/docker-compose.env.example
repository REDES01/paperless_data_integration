# Paperless-ngx environment file — rename to docker-compose.env before use.
# Generate PAPERLESS_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"

# Host address — leave commented for default
#PAPERLESS_URL=https://paperless.example.com

# Time zone and OCR languages
PAPERLESS_TIME_ZONE=America/New_York
PAPERLESS_OCR_LANGUAGE=eng

# Secret key — REQUIRED for source builds. Do not commit a real one.
PAPERLESS_SECRET_KEY=replace-me-with-a-real-secret

# Database (matches services in docker-compose.yml)
PAPERLESS_DBHOST=db
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=paperless

# Redis broker
PAPERLESS_REDIS=redis://broker:6379
