{
  "id": null,
  "title": "ML Gateway — Serving Monitoring",
  "timezone": "browser",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTR Request Rate (per second)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [ { "expr": "sum(rate(htr_requests_total[1m]))", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTR Error Rate",
      "datasource": "Prometheus",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "sum(rate(htr_requests_total{status!=\"ok\"}[5m])) / clamp_min(sum(rate(htr_requests_total[5m])), 0.001)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Search Request Rate (per second)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [ { "expr": "sum(rate(search_requests_total[1m]))", "refId": "A" } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg HTR Confidence (last 5m)",
      "datasource": "Prometheus",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "sum(rate(htr_confidence_sum[5m])) / clamp_min(sum(rate(htr_confidence_count[5m])), 0.001)", "refId": "A" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTR Latency (p50/p95/p99)",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 10 },
      "targets": [
        { "expr": "histogram_quantile(0.5,  sum(rate(htr_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(htr_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(htr_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "options": { "legend": { "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Search Latency (p50/p95/p99)",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 10 },
      "targets": [
        { "expr": "histogram_quantile(0.5,  sum(rate(search_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(search_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(search_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "options": { "legend": { "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTR Confidence Distribution",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (le) (rate(htr_confidence_bucket[5m]))", "legendFormat": "{{le}}", "refId": "A" }
      ],
      "options": { "legend": { "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTR Requests by Status",
      "datasource": "Prometheus",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (status) (rate(htr_requests_total[1m]))", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "options": { "legend": { "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ]
}
